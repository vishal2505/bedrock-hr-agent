*.py[cod]
*.egg-info/
venv/
.venv/
*.pyc

# ─── Environment / secrets ───────────────────────────────────────────────────
.env
*.env
!*.env.example                         # keep example files

# ─── Node / Frontend ─────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/

# ─── Docker ──────────────────────────────────────────────────────────────────
*.log

