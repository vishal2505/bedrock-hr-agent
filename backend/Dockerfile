# Build context is the PROJECT ROOT (docker build -f backend/Dockerfile .)
FROM python:3.11-slim

WORKDIR /app

# Copy only the requirements first for better layer caching
COPY backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend package — preserves the `backend/` namespace so
# `uvicorn backend.main:app` resolves correctly inside the container
COPY backend/ ./backend/

EXPOSE 8000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
